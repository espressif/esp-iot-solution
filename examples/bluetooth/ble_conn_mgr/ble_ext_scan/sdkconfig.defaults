# Override some defaults so BT stack is enabled
# by default in this example
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_EXT_ADV=y

CONFIG_BLE_CONN_MGR_ROLE_CENTRAL=y
# Extended scan only (no periodic sync)
CONFIG_BLE_CONN_MGR_PERIODIC_SYNC=n
# Per-fragment buffer for extended reports (HCI fragment up to 255 B)
CONFIG_BLE_CONN_MGR_SCAN_RESULT_ADV_MAX_LEN=255
