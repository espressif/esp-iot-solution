CONFIG_BOOTLOADER_LOG_LEVEL_ERROR=y
CONFIG_BOOTLOADER_SKIP_VALIDATE_ALWAYS=y

CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=y
CONFIG_BT_LE_SLEEP_ENABLE=y

CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y

CONFIG_LOG_DEFAULT_LEVEL_WARN=y

CONFIG_OPENTHREAD_RX_ON_WHEN_IDLE=y
CONFIG_GPIO_BUTTON_SUPPORT_POWER_SAVE=y

CONFIG_BT_CTRL_SLEEP_ENABLE=y
CONFIG_BT_CTRL_LP_CLK_SRC_DEFAULT=y
CONFIG_PM_POWER_DOWN_PERIPHERAL_IN_LIGHT_SLEEP=y
CONFIG_EXAMPLE_BUTTON_KNOB_USE_RTC_IO=y

# RTC slow clock: external 32 kHz crystal (lower sleep current than INT_RC)
CONFIG_RTC_CLK_SRC_EXT_CRYS=y
