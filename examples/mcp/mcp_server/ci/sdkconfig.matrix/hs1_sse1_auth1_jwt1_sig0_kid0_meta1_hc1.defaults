# HTTP_SERVER=y,SSE=y,AUTH=y,JWT=y,VERIFY_SIG=n,REQUIRE_KID=n,OAUTH_META=y,HTTP_CLIENT=y
CONFIG_MCP_TRANSPORT_HTTP_SERVER=y
CONFIG_MCP_TRANSPORT_HTTP_CLIENT=y
CONFIG_MCP_HTTP_SSE_ENABLE=y
CONFIG_MCP_HTTP_OAUTH_METADATA_ENABLE=y
CONFIG_MCP_HTTP_AUTH_ENABLE=y
CONFIG_MCP_HTTP_AUTH_BEARER_TOKEN="mcp-dev-token"
CONFIG_MCP_HTTP_AUTH_REQUIRED_SCOPE="mcp:full"
CONFIG_MCP_HTTP_AUTH_SCOPE_ENABLE=n
CONFIG_MCP_HTTP_AUTH_JWT_VERIFY_ENABLE=y
CONFIG_MCP_HTTP_AUTH_JWT_EXPECT_ISS="https://example.local"
CONFIG_MCP_HTTP_AUTH_JWT_EXPECT_AUD="mcp://esp32"
CONFIG_MCP_HTTP_AUTH_JWT_REQUIRE_KID=n
CONFIG_MCP_HTTP_AUTH_JWT_VERIFY_SIGNATURE=n
CONFIG_MCP_HTTP_AUTH_JWT_CLOCK_SKEW_SEC=60
CONFIG_MCP_HTTP_DEFAULT_PROTOCOL_VERSION="2025-03-26"
