menu "Example Configuration"

    config EXAMPLE_NODE_NAME
        string "Node name"
        default "ESP Weaver Device"
        help
            Name of the Weaver node, used for device identification.

    config EXAMPLE_NODE_TYPE
        string "Node type"
        default "Lightbulb"
        help
            Type of the Weaver node (e.g. Lightbulb, Sensor, Switch).

    config EXAMPLE_DEVICE_NAME
        string "Device display name"
        default "Light"
        help
            Display name advertised via mDNS TXT record for local discovery.

    config EXAMPLE_BOARD_BUTTON_GPIO
        int "Boot Button GPIO"
        default 28 if IDF_TARGET_ESP32C5
        default 9 if IDF_TARGET_ESP32C3 || IDF_TARGET_ESP32C6 || IDF_TARGET_ESP32C2 || IDF_TARGET_ESP32C61
        default 0
        help
            GPIO number on which the "Boot" button is connected. This is generally used
            by the application for custom operations like toggling states, resetting to defaults, etc.

    choice LED_TYPE
        prompt "LED Type"
        default LED_TYPE_RGB if IDF_TARGET_ESP32 || IDF_TARGET_ESP32C2
        default LED_TYPE_WS2812
        help
            Select the type of LED to use.
            - ESP32 DevKit: No built-in LED, use external 3-pin RGB LED module
            - ESP8684-DevKitM-1 (ESP32-C2): Built-in 3-pin RGB LED (not WS2812)
            - Other DevKits (S3, C3, C6, C61, etc.): Built-in WS2812 addressable LED

        config LED_TYPE_RGB
            bool "RGB LED (3-pin RGB LED)"
            help
                Use a 3-pin RGB LED with separate GPIO pins for red, green, and blue.

        config LED_TYPE_WS2812
            bool "WS2812 LED Strip"
            help
                Use WS2812 addressable LED strip.

        config LED_TYPE_NONE
            bool "No LED"
            help
                Disable LED hardware. Useful for testing without LED hardware connected.
    endchoice

    config RGB_LED_RED_GPIO
        int "RGB LED Red GPIO"
        default 25 if IDF_TARGET_ESP32
        default 0
        depends on LED_TYPE_RGB
        help
            GPIO number for the red channel of the RGB LED.
            ESP32 DevKit has no built-in RGB LED. Default pins (25, 26, 27)
            are for external 3-pin RGB LED module (active high/common cathode).

    config RGB_LED_GREEN_GPIO
        int "RGB LED Green GPIO"
        default 26 if IDF_TARGET_ESP32
        default 1
        depends on LED_TYPE_RGB
        help
            GPIO number for the green channel of the RGB LED.

    config RGB_LED_BLUE_GPIO
        int "RGB LED Blue GPIO"
        default 27 if IDF_TARGET_ESP32
        default 8
        depends on LED_TYPE_RGB
        help
            GPIO number for the blue channel of the RGB LED.

    config RGB_LED_ACTIVE_LEVEL_HIGH
        bool "RGB LED Active Level High"
        default y if IDF_TARGET_ESP32
        default n
        depends on LED_TYPE_RGB
        help
            Set to y if the RGB LED is active high (common cathode), n if active low (common anode).
            ESP32 defaults to active high for external common cathode RGB LED module.

    config WS2812_LED_GPIO
        int "WS2812 LED GPIO"
        default 27 if IDF_TARGET_ESP32C5
        default 8 if IDF_TARGET_ESP32C61 || IDF_TARGET_ESP32C2 || IDF_TARGET_ESP32C3 || IDF_TARGET_ESP32C6
        default 38 if IDF_TARGET_ESP32S3
        default 18
        depends on LED_TYPE_WS2812
        help
            GPIO number for the WS2812 RGB LED strip.
            Default values are based on official DevKit boards:
            - ESP32-S3: GPIO38
            - ESP32-C2/C3/C6/C61: GPIO8
            - ESP32-C5: GPIO27
            - Others: GPIO18

    config WS2812_LED_COUNT
        int "Number of WS2812 LEDs"
        default 1
        range 1 256
        depends on LED_TYPE_WS2812
        help
            Number of LEDs in the WS2812 strip.

endmenu
