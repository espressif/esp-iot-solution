     }
     return ret;
 }
+
+esp_err_t esp_local_ctrl_send_data(const uint8_t *data, size_t len)
+{
+    if (!local_ctrl_inst_ctx) {
+        ESP_LOGE(TAG, "Service not running");
+        return ESP_ERR_INVALID_STATE;
+    }
+    if (!data || len == 0) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    if (!local_ctrl_inst_ctx->config.transport->send_data) {
+        ESP_LOGE(TAG, "Transport does not support sending data");
+        return ESP_ERR_NOT_SUPPORTED;
+    }
+    uint8_t *outbuf = NULL;
+    ssize_t outlen = 0;
+    esp_err_t ret = esp_local_ctrl_data_generate_report_payload(data, len, &outbuf, &outlen, NULL);
+    if (ret != ESP_OK) {
+        ESP_LOGE(TAG, "Failed to generate report payload");
+        return ret;
+    }
+    ret = local_ctrl_inst_ctx->config.transport->send_data(local_ctrl_inst_ctx->pc, outbuf, outlen);
+    free(outbuf);
+    if (ret != ESP_OK) {
+        ESP_LOGE(TAG, "Failed to send data, ret: %d", ret);
+    }
+    return ret;
+}
