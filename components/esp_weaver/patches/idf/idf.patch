+
+esp_err_t esp_local_ctrl_data_generate_report_payload(const uint8_t *inbuf, ssize_t inlen, uint8_t **outbuf, ssize_t *outlen, void *priv_data)
+{
+    LocalCtrlMessage resp;
+    if (!inbuf || inlen <= 0) {
+        ESP_LOGE(TAG, "Invalid input buffer");
+        return ESP_ERR_INVALID_ARG;
+    }
+    local_ctrl_message__init(&resp);
+    resp.msg = LOCAL_CTRL_MSG_TYPE__TypeReportPropertyValues;
+    resp.payload_case = LOCAL_CTRL_MESSAGE__PAYLOAD_REPORT_PROP_VALS;
+    resp.report_prop_vals = malloc(sizeof(ReportPropertyValues));
+    if (!resp.report_prop_vals) {
+        ESP_LOGE(TAG, "Failed to allocate memory for report payload");
+        return ESP_ERR_NO_MEM;
+    }
+    report_property_values__init(resp.report_prop_vals);
+    resp.report_prop_vals->n_props = 1;
+    resp.report_prop_vals->props = calloc(1, sizeof(PropertyValue *));
+    if (!resp.report_prop_vals->props) {
+        ESP_LOGE(TAG, "Failed to allocate memory for report payload");
+        free(resp.report_prop_vals);
+        return ESP_ERR_NO_MEM;
+    }
+    resp.report_prop_vals->props[0] = malloc(sizeof(PropertyValue));
+    if (!resp.report_prop_vals->props[0]) {
+        ESP_LOGE(TAG, "Failed to allocate memory for report payload");
+        free(resp.report_prop_vals->props);
+        free(resp.report_prop_vals);
+        return ESP_ERR_NO_MEM;
+    }
+    property_value__init(resp.report_prop_vals->props[0]);
+    resp.report_prop_vals->props[0]->index = 0;
+    resp.report_prop_vals->props[0]->value.data = (uint8_t *)malloc(inlen);
+    if (!resp.report_prop_vals->props[0]->value.data) {
+        ESP_LOGE(TAG, "Failed to allocate memory for report payload");
+        free(resp.report_prop_vals->props[0]);
+        free(resp.report_prop_vals->props);
+        free(resp.report_prop_vals);
+        return ESP_ERR_NO_MEM;
+    }
+    memcpy(resp.report_prop_vals->props[0]->value.data, inbuf, inlen);
+    resp.report_prop_vals->props[0]->value.len = inlen;
+    *outlen = local_ctrl_message__get_packed_size(&resp);
+    if (*outlen <= 0) {
+        ESP_LOGE(TAG, "Invalid encoding for response");
+        free(resp.report_prop_vals->props[0]->value.data);
+        free(resp.report_prop_vals->props[0]);
+        free(resp.report_prop_vals->props);
+        free(resp.report_prop_vals);
+        return ESP_FAIL;
+    }
+
+    *outbuf = (uint8_t *) malloc(*outlen);
+    if (!*outbuf) {
+        ESP_LOGE(TAG, "System out of memory");
+        free(resp.report_prop_vals->props[0]->value.data);
+        free(resp.report_prop_vals->props[0]);
+        free(resp.report_prop_vals->props);
+        free(resp.report_prop_vals);
+        return ESP_ERR_NO_MEM;
+    }
+
+    local_ctrl_message__pack(&resp, *outbuf);
+    free(resp.report_prop_vals->props[0]->value.data);
+    free(resp.report_prop_vals->props[0]);
+    free(resp.report_prop_vals->props);
+    free(resp.report_prop_vals);
+    return ESP_OK;
+}
