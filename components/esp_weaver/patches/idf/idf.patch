+esp_err_t protocomm_httpd_send_data(protocomm_t *pc, const uint8_t *data, size_t len)
+{
+    esp_err_t ret = ESP_FAIL;
+    bool is_encrypted = false;
+    if (!pc || pc != pc_httpd) {
+        ESP_LOGE(TAG, "Invalid protocomm instance");
+        return ESP_ERR_INVALID_STATE;
+    }
+
+    if (current_socket_fd == -1) {
+        ESP_LOGE(TAG, "Invalid current socket file descriptor");
+        return ESP_ERR_INVALID_STATE;
+    }
+
+#define HTTPD_HDR_STR      "EVENT/1.0 200 OK\r\n"      \
+    "Content-Type: application/hap+json\r\n"           \
+    "Content-Length: %d\r\n\r\n"
+
+    uint8_t *enc_data = NULL;
+    ssize_t enc_data_len = 0;
+    
+    /* Acquire mutex before encryption and send operations */
+    if (xSemaphoreTake(protocomm_httpd_mutex, portMAX_DELAY) != pdTRUE) {
+        ESP_LOGE(TAG, "Failed to acquire mutex");
+        return ESP_FAIL;
+    }
+    
+    if (pc->sec && pc->sec->encrypt) {
+
+        ret = pc->sec->encrypt(pc->sec_inst, cookie_session_id, data, len,
+                           &enc_data, &enc_data_len);
+        if (ret != ESP_OK) {
+            ESP_LOGE(TAG, "Encryption of response failed");
+            xSemaphoreGive(protocomm_httpd_mutex);
+            goto out;
+        }
+        is_encrypted = true;
+    } else {
+        enc_data = (uint8_t *)data;
+        enc_data_len = len;
+    }
+
+    // Prepare HTTP header
+    char httpd_hdr_str[128] = {0};
+    int hdr_len = snprintf(httpd_hdr_str, sizeof(httpd_hdr_str), HTTPD_HDR_STR, enc_data_len);
+    
+    // Allocate buffer for header + body
+    size_t total_len = hdr_len + enc_data_len;
+    char *send_buf = (char *)malloc(total_len);
+    if (!send_buf) {
+        ESP_LOGE(TAG, "Failed to allocate send buffer, size: %zu", total_len);
+        ret = ESP_ERR_NO_MEM;
+        xSemaphoreGive(protocomm_httpd_mutex);
+        goto out;
+    }
+    
+    // Copy header and body into single buffer
+    memcpy(send_buf, httpd_hdr_str, hdr_len);
+    memcpy(send_buf + hdr_len, enc_data, enc_data_len);
+    
+    // Send header + body together
+    int send_len = send(current_socket_fd, send_buf, total_len, 0);
+    
+    /* Release mutex after send operations */
+    xSemaphoreGive(protocomm_httpd_mutex);
+    
+    free(send_buf);
+    
+    if (send_len <= 0) {
+        ESP_LOGE(TAG, "Failed to send HTTP response, send_len: %d", send_len);
+        ret = ESP_FAIL;
+        goto out;
+    }
+    ret = ESP_OK;
+out:
+    if (is_encrypted) {
+        free(enc_data);
+    }
+    return ret;
+}
