+/**
+ * @brief   Send data over the transport
+ *
+ * This API can be called by the application to send data over the transport.
+ *
+ * @note In case of BLE transport the data is sent over the BLE transport.
+ * In case of HTTPD transport the data is sent over the HTTPD transport.
+ *
+ * @param[in] data    Pointer to data to send
+ * @param[in] len     Length of data to send
+ *
+ * @return
+ *  - ESP_OK      : Success
+ *  - ESP_FAIL    : Failure
+ */
+esp_err_t esp_local_ctrl_send_data(const uint8_t *data, size_t len);
+
 #ifdef __cplusplus
